# Firebase (Web/Client) - from Firebase Console > Project Settings > Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In - Web client ID from Firebase/Google Cloud Console
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Backend API URL (default: http://localhost:4000 in dev)
EXPO_PUBLIC_API_URL=

# Room share links: HTTPS page (clickable in Gmail/Google Chat). Upload hosting/invite.html to this origin.
# Example: https://yourname.netlify.app  → share link becomes https://yourname.netlify.app/invite.html?room=fireplace
EXPO_PUBLIC_ROOM_INVITE_WEB_URL=

# Optional: override app.json scheme in shared myapp:// links (when web URL above is not set)
# EXPO_PUBLIC_APP_LINK_SCHEME=myapp
