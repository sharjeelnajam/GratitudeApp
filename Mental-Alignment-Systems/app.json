{
  "expo": {
    "name": "Gratitude Keeper",
    "slug": "mental-alignment-systems",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/geometry.jpeg",
    "splash": {
      "image": "./assets/images/geometry.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#0A0714",
      "dark": {
        "backgroundColor": "#0A0714"
      }
    },
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "android.permission.HIGH_SAMPLING_RATE_SENSORS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0A0714",
        "foregroundImage": "./assets/images/geometry.jpeg",
        "monochromeImage": "./assets/images/geometry.jpeg"
      },
      "backgroundColor": "#0A0714",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.devhamza.mentalalignmentsystems"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/geometry.jpeg",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0A0714",
          "dark": {
            "backgroundColor": "#0A0714"
          }
        }
      ],
      "expo-asset",
      "expo-audio",
      "expo-video",
      [
        "expo-sensors",
        {
          "motionPermission": "Allow $(PRODUCT_NAME) to access your device motion for subtle background effects in rooms."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7a5a1023-f855-4c79-bbe1-e022e55cfa6e"
      }
    }
  }
}
